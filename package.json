{
  "name": "elux-ui",
  "version": "1.0.0",
  "description": "AI-Powered System Command Center with Biometric Authentication",
  "main": "electron/main.js",
  "author": "Your Name",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run watch:renderer\" \"npm run watch:main\" \"wait-on http://localhost:3000 && electron .\"",
    "watch:renderer": "webpack serve --config webpack.config.js --mode development",
    "watch:main": "webpack --config webpack.main.config.js --mode development --watch",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "webpack --config webpack.config.js --mode production",
    "build:main": "webpack --config webpack.main.config.js --mode production",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "test": "jest",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.7",
    "@xterm/xterm": "^5.3.0",
    "@xterm/addon-fit": "^0.7.0",
    "@xterm/addon-web-links": "^0.8.0",
    "@xterm/addon-canvas": "^0.5.0",
    "@xterm/addon-search": "^0.11.0",
    "@xterm/addon-image": "^0.6.0",
    "electron-log": "^4.4.8",
    "electron-store": "^8.1.0",
    "electron-rebuild": "^3.2.9",
    "face-api.js": "^0.22.2",
    "framer-motion": "^10.16.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.3",
    "recharts": "^2.10.3",
    "sqlite3": "^5.1.6",
    "systeminformation": "^5.21.24",
    "node-pcap": "^2.1.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "canvas": "^2.11.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.3",
    "@testing-library/react": "^14.1.2",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "electron": "^27.1.0",
    "electron-builder": "^24.9.1",
    "electron-devtools-installer": "^3.2.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "html-webpack-plugin": "^5.5.4",
    "jest": "^29.7.0",
    "postcss": "^8.4.32",
    "postcss-loader": "^7.3.4",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.6",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "build": {
    "appId": "com.elux-ui.app",
    "productName": "e-LuX-UI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "backend/**/*",
      "database/**/*",
      "ai/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}